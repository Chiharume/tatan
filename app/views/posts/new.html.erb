<div class="newtokou">
    <h1>Post your art</h1><br>
    <div class="hello">
        <%= form_for @post do |f| %>
        
        <div class="field">
            <b><%= f.label :title %>:</b><br>
            <%= f.text_field :title, :size => 30 %>
        </div>

        <div class="field">
            <b><%= f.label :Description  %>:</b>
            <%= f.text_area :body, :size => "30x2" %>
        </div>

        <div class="field">
            <b><%= f.label :image %>:</b>
            <%= f.file_field :image %>
        </div><br>

        <%= f.submit "投稿する" %>
    </div>
    <% end %>
</div>

